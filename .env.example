# ─────────────────────────────────────────────────────────────────────────────
# Breaking Magic — environment variables
#
# Copy this file to `.env.local` (which is gitignored) and fill in real values.
# In production (e.g. Vercel), set these in the project's Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase (your NEW project) → Project Settings → API
SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"
# The service_role secret key. SERVER-ONLY — never prefix with NEXT_PUBLIC_,
# never expose to the browser. It bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret-key"

# Resend (https://resend.com) — used to email you each new application.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Where new-application alerts are DELIVERED. Use a DIFFERENT address than the
# sender below — a self-addressed send (from X to the same X) is frequently
# delayed or dropped by mail providers. e.g. "applications@breakingmagic.com".
APPLICATIONS_NOTIFY_EMAIL="applications@yourdomain.com"
# Sender address the alert is sent FROM. For first-run testing you can leave
# this unset and Resend's shared "onboarding@resend.dev" sender is used. For
# production, verify your domain in Resend and set e.g. "apply@yourdomain.com".
APPLICATIONS_FROM_EMAIL="apply@yourdomain.com"

# Shared secret for the MagicOS integration (GET/PATCH /api/applications).
# Generate a strong random value, e.g.:  openssl rand -base64 32
# Put the SAME value in MagicOS's environment. Rotating it here revokes
# MagicOS's access instantly. If unset, those endpoints reject every request.
MAGICOS_API_TOKEN=""
